		"editor.selectionBackground": "#59BCFB4D",
		"editor.selectionHighlightBackground": "#00000000",
		"editor.selectionHighlightBorder": "#59BCFBB3",
		"editor.wordHighlightBackground": "#00000000",
		"editor.wordHighlightBorder": "#59BCFBB3",
		"editor.wordHighlightStrongBackground": "#00000000",
		"editor.wordHighlightStrongBorder": "#59BCFBB3",
		"editor.wordHighlightTextBackground": "#00000000",
		"editor.wordHighlightTextBorder": "#59BCFBB3",
		"editorBracketHighlight.foreground1": "#E3B248",
		"editorBracketHighlight.foreground2": "#E094F1",
		"editorBracketHighlight.foreground3": "#53D2EC",
		"editorBracketHighlight.foreground4": "#E3B248",
		"editorBracketHighlight.foreground5": "#E094F1",
		"editorBracketHighlight.foreground6": "#53D2EC",
		"editorBracketHighlight.unexpectedBracket.foreground": "#E0666E",
		"editorGroup.border": "#FFFFFF17",
		"editorGroupHeader.tabsBackground": "#181818",
		"editorGroupHeader.tabsBorder": "#2B2B2B",
		"editorGutter.addedBackground": "#3B9E4A",
		"editorGutter.deletedBackground": "#F15A51",
		"editorGutter.modifiedBackground": "#1E79CC",
		"editorIndentGuide.activeBackground1": "#707070",
		"editorIndentGuide.background1": "#404040",
		"editorLineNumber.activeForeground": "#CCCCCC",
		"editorLineNumber.foreground": "#6E7681",
		"editorOverviewRuler.border": "#010409",
		"editorWidget.background": "#202020",
		"errorForeground": "#F15A51",
		"focusBorder": "#1E79CC",
		"foreground": "#CCCCCC",
		"icon.foreground": "#CCCCCC",
		"input.background": "#313131",
		"input.border": "#3C3C3C",
		"input.foreground": "#CCCCCC",
		"input.placeholderForeground": "#818181",
		"inputOption.activeBackground": "#3289D482",
		"inputOption.activeBorder": "#3288D4",
		"keybindingLabel.foreground": "#CCCCCC",
		"list.activeSelectionIconForeground": "#FFFFFF",
		"list.dropBackground": "#383B3D",
		"menu.background": "#1F1F1F",
		"menu.border": "#454545",
		"menu.foreground": "#CCCCCC",
		"menu.separatorBackground": "#454545",
		"notificationCenterHeader.background": "#1F1F1F",
		"notificationCenterHeader.foreground": "#CCCCCC",
		"notifications.background": "#1F1F1F",
		"notifications.border": "#2B2B2B",
		"notifications.foreground": "#CCCCCC",
		"panel.background": "#181818",
		"panel.border": "#2B2B2B",
		"panelInput.border": "#2B2B2B",
		"panelTitle.activeBorder": "#1E79CC",
		"panelTitle.activeForeground": "#CCCCCC",
		"panelTitle.inactiveForeground": "#9D9D9D",
		"peekViewEditor.background": "#1F1F1F",
		"peekViewEditor.matchHighlightBackground": "#C6A23380",
		"peekViewResult.background": "#1F1F1F",
		"peekViewResult.matchHighlightBackground": "#C6A23380",
		"pickerGroup.border": "#3C3C3C",
		"ports.iconRunningProcessForeground": "#3E933A",
		"progressBar.background": "#1E79CC",
		"quickInput.background": "#222222",
		"quickInput.foreground": "#CCCCCC",
		"settings.dropdownBackground": "#313131",
		"settings.dropdownBorder": "#3C3C3C",
		"settings.headerForeground": "#FFFFFF",
		"settings.modifiedItemIndicator": "#B7822666",
		"sideBar.background": "#181818",
		"sideBar.border": "#2B2B2B",
		"sideBar.foreground": "#CCCCCC",
		"sideBarSectionHeader.background": "#181818",
		"sideBarSectionHeader.border": "#2B2B2B",
		"sideBarSectionHeader.foreground": "#CCCCCC",
		"sideBarTitle.foreground": "#CCCCCC",
		"statusBar.background": "#181818",
		"statusBar.border": "#2B2B2B",
		"statusBar.debuggingBackground": "#1E79CC",
		"statusBar.debuggingForeground": "#FFFFFF",
		"statusBar.focusBorder": "#1E79CC",
		"statusBar.foreground": "#CCCCCC",
		"statusBar.noFolderBackground": "#1F1F1F",
		"statusBarItem.focusBorder": "#1E79CC",
		"statusBarItem.prominentBackground": "#6E768166",
		"statusBarItem.remoteBackground": "#1E79CC",
		"statusBarItem.remoteForeground": "#FFFFFF",
		"tab.activeBackground": "#1F1F1F",
		"tab.activeBorder": "#1F1F1F",
		"tab.activeBorderTop": "#1E79CC",
		"tab.activeForeground": "#FFFFFF",
		"tab.border": "#2B2B2B",
		"tab.hoverBackground": "#1F1F1F",
		"tab.inactiveBackground": "#181818",
		"tab.inactiveForeground": "#9D9D9D",
		"tab.lastPinnedBorder": "#CCCCCC33",
		"tab.unfocusedActiveBorder": "#1F1F1F",
		"tab.unfocusedActiveBorderTop": "#2B2B2B",
		"tab.unfocusedHoverBackground": "#1F1F1F",
		"terminal.foreground": "#CCCCCC",
		"terminal.inactiveSelectionBackground": "#3A3D4180",
		"terminal.tab.activeBorder": "#1E79CC",
		"textBlockQuote.background": "#2B2B2B",
		"textBlockQuote.border": "#616161",
		"textCodeBlock.background": "#2B2B2B",
		"textLink.activeForeground": "#58AAF5",
		"textLink.foreground": "#58AAF5",
		"textPreformat.background": "#3C3C3C",
		"textPreformat.foreground": "#D0D0D0",
		"textSeparator.foreground": "#21262D",
		"titleBar.activeBackground": "#181818",
		"titleBar.activeForeground": "#CCCCCC",
		"titleBar.border": "#2B2B2B",
		"titleBar.inactiveBackground": "#1F1F1F",
		"titleBar.inactiveForeground": "#9D9D9D",
		"welcomePage.progress.foreground": "#1E79CC",
		"welcomePage.tileBackground": "#2B2B2B",
		"widget.border": "#313131"
	},
	"semanticTokenColors": {
		"namespace:csharp": "#B8B8B8",
		"class:csharp": "#56CBAD",
		"struct:csharp": "#93C57A",
		"interface:csharp": "#53C4D9",
		"enum:csharp": "#B1BF73",
		"enumMember:csharp": "#D4B68B",
		"typeParameter:csharp": "#8AB2FC",
		"method:csharp": "#C5C391",
		"function:csharp": "#C5C391",
		"property:csharp": "#98C8E1",
		"event:csharp": "#98C8E1",
		"variable.local:csharp": "#B8B8B8",
		"parameter:csharp": {
			"foreground": "#A6C8B1"
		},
		"variable.readonly:csharp": "#D4B68B",
		"property.readonly:csharp": "#D4B68B"
	},
	"tokenColors": [
		{
			"scope": [
				"meta.embedded",
				"source.groovy.embedded",
				"string meta.image.inline.markdown",
				"variable.legacy.builtin.python"
			],
			"settings": {
				"foreground": "#D4D4D4"
			}
		},
		{
			"scope": "emphasis",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "strong",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": "invalid",
			"settings": {
				"foreground": "#DD616B"
			}
		},
		{
			"scope": "markup.underline",
			"settings": {
				"fontStyle": "underline"
			}
		},
		{
			"scope": [
				"markup.bold",
				"markup.heading"
			],
			"settings": {
				"foreground": "#53A8C4",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "markup.strikethrough",
			"settings": {
				"fontStyle": "strikethrough"
			}
		},
		{
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#80CC55"
			}
		},
		{
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#C8978B"
			}
		},
		{
			"scope": "markup.changed",
			"settings": {
				"foreground": "#53A8C4"
			}
		},
		{
			"scope": "markup.inline.raw",
			"settings": {
				"foreground": "#C8978B"
			}
		},
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#6F8498"
			}
		},
		{
			"scope": "comment.documentation",
			"settings": {
				"foreground": "#817DAE"
			}
		},
		{
			"scope": [
				"string",
				"string.tag",
				"string.value"
			],
			"settings": {
				"foreground": "#C8978B"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"keyword.operator.plus.exponent",
				"keyword.operator.minus.exponent"
			],
			"settings": {
				"foreground": "#D4B68B"
			}
		},
		{
			"scope": [
				"constant.character.escape",
				"constant.other.option"
			],
			"settings": {
				"foreground": "#D4B68B"
			}
		},
		{
			"scope": [
				"constant.language",
				"variable.language"
			],
			"settings": {
				"foreground": "#639FD8"
			}
		},
		{
			"scope": "keyword",
			"settings": {
				"foreground": "#639FD8"
			}
		},
		{
			"scope": [
				"keyword.control",
				"source.cpp keyword.operator.new",
				"keyword.operator.delete",
				"keyword.other.using",
				"keyword.other.directive.using",
				"keyword.other.operator",
				"entity.name.operator"
			],
			"settings": {
				"foreground": "#CB8AA7"
			}
		},
		{
			"scope": "keyword.operator",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"entity.name.function.member.overload",
				"entity.name.type.delegate",
				"entity.name.type.delegate.cs"
			],
			"settings": {
				"foreground": "#C5C391"
			}
		},
		{
			"scope": "entity.name.namespace",
			"settings": {
				"foreground": "#B8B8B8"
			}
		},
		{
			"scope": [
				"storage",
				"storage.type",
				"storage.modifier",
				"storage.type.cs",
				"storage.type.generic.cs",
				"storage.type.modifier.cs",
				"storage.type.variable.cs",
				"keyword.operator.noexcept"
			],
			"settings": {
				"foreground": "#639FD8"
			}
		},
		{
			"scope": [
				"entity.name.type.class",
				"entity.other.inherited-class"
			],
			"settings": {
				"foreground": "#56CBAD"
			}
		},
		{
			"scope": "entity.name.type.struct",
			"settings": {
				"foreground": "#93C57A"
			}
		},
		{
			"scope": "entity.name.type.interface",
			"settings": {
				"foreground": "#53C4D9"
			}
		},
		{
			"scope": "entity.name.type.enum",
			"settings": {
				"foreground": "#B1BF73"
			}
		},
		{
			"scope": [
				"entity.name.type.type-parameter"
			],
			"settings": {
				"foreground": "#8AB2FC"
			}
		},
		{
			"scope": [
				"variable.other.property",
				"entity.name.variable.field"
			],
			"settings": {
				"foreground": "#98C8E1"
			}
		},
		{
			"scope": [
				"entity.name.variable.event",
				"variable.other.event"
			],
			"settings": {
				"foreground": "#98C8E1"
			}
		},
		{
			"scope": [
				"variable.other.readwrite",
				"entity.name.variable.local"
			],
			"settings": {
				"foreground": "#B8B8B8"
			}
		},
		{
			"scope": [
				"variable.other.constant",
				"variable.other.enummember"
			],
			"settings": {
				"foreground": "#D4B68B"
			}
		},
		{
			"scope": "variable.parameter",
			"settings": {
				"foreground": "#A6C8B1"
			}
		},
		{
			"scope": "punctuation.separator.comma",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "punctuation.terminator.statement",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "punctuation.curlybrace",
			"settings": {
				"foreground": "#53D2EC"
			}
		},
		{
			"scope": "punctuation.parenthesis",
			"settings": {
				"foreground": "#E094F1"
			}
		},
		{
			"scope": [
				"punctuation.squarebracket",
				"punctuation.definition.typeparameters"
			],
			"settings": {
				"foreground": "#E3B248"
			}
		},
		{
			"scope": "token.info-token",
			"settings": {
				"foreground": "#3BA3CC"
			}
		},
		{
			"scope": "token.warn-token",
			"settings": {
				"foreground": "#D2934F"
			}
		},
		{
			"scope": "token.error-token",
			"settings": {
				"foreground": "#DD616B"
			}
		},
		{
			"scope": "token.debug-token",
			"settings": {
				"foreground": "#967AE2"
			}
		}
	]
}
